# Core service endpoints
OLLAMA_HOST=http://localhost:11434
BACKEND_PORT=8000
RAG_API_PORT=8001
FRONTEND_PORT=3000

# Model selection
GENERATION_MODEL=gemma3:27b-cloud
ENRICHMENT_MODEL=gemma3:12b-cloud
EMBEDDING_MODEL=nomic-embed-text:v1.5
RERANKER_MODEL=answerdotai/answerai-colbert-small-v1
RAG_CONFIG_MODE=default

# Storage paths
DATABASE_PATH=./backend/chat_data.db
VECTOR_DB_PATH=./lancedb
LANCEDB_PATH=./lancedb

# Optional indexing safety controls
RAG_LARGE_PDF_SIZE_MB=40
RAG_LARGE_PDF_PAGE_THRESHOLD=150
RAG_SEGMENTED_PDF_PAGE_THRESHOLD=120
RAG_SEGMENT_PAGE_WINDOW=40
RAG_MAX_EMBED_BATCH=24
RAG_MAX_ENRICH_BATCH=24
RAG_MIN_EMBED_BATCH=4
RAG_MIN_ENRICH_BATCH=2
RAG_LOW_MEMORY_THRESHOLD_MB=3072
RAG_INDEXING_TARGET_MEM_MB=1024

# Optional model/runtime controls
RAG_LOG_LEVEL=INFO
RAG_ENRICH_PROMPT_MAX_TOKENS=3000
RAG_ENRICH_MIN_SUMMARY_CHARS=5
RAG_SYNTHESIS_MAX_CONTEXT_CHARS=32000
RAG_COMPOSE_MAX_CONTEXT_CHARS=24000

# Optional Ollama resilience controls
OLLAMA_REQUEST_TIMEOUT_SEC=60
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_BACKOFF_SEC=1.5
OLLAMA_CIRCUIT_BREAKER_THRESHOLD=5
OLLAMA_CIRCUIT_BREAKER_RESET_SEC=30
OLLAMA_PROMPT_RETRY_ATTEMPTS=5
OLLAMA_PROMPT_CHAR_HARD_CAP=12000
