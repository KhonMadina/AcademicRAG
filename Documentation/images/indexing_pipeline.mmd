    G --> H[5. Generate Embeddings]
    H --> I[6. Store Vectors in LanceDB]
    I --> J[7. Save Metadata in SQLite]

    classDef step fill:#eef8ef,stroke:#2d7d46,stroke-width:1.2px,color:#123;
    classDef decision fill:#fff5e6,stroke:#b26a00,stroke-width:1.2px,color:#333;
    class A,B,D,E,F,G,H,I,J step;
    class C decision;